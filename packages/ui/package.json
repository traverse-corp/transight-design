{
  "name": "@transight-design/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Transight UI — copy-paste components built on Base UI + Tailwind v4",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "registry.json",
    "public/r"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles/*": "./src/styles/*",
    "./components/*": "./src/components/*.tsx",
    "./tokens/*": "./src/tokens/*.ts",
    "./tokens": "./src/tokens/index.ts",
    "./lib/*": "./src/lib/*.ts",
    "./lib/hooks/*": "./src/lib/hooks/*"
  },
  "scripts": {
    "build:icons": "node scripts/build-icons.mjs",
    "prebuild": "node scripts/build-icons.mjs",
    "predev": "node scripts/build-icons.mjs",
    "pretypecheck": "node scripts/build-icons.mjs",
    "build": "npm run registry:generate && npm run registry:build",
    "rewrite-imports": "node scripts/rewrite-imports.mjs",
    "registry:generate": "node scripts/build-registry.mjs",
    "registry:validate": "shadcn registry validate ./registry.json",
    "registry:build": "shadcn build ./registry.json --output ./public/r && npm run registry:transform",
    "registry:transform": "node scripts/transform-built-imports.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint config lands in Phase 3\"",
    "clean": "rm -rf dist .turbo public/r"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.0.0",
    "react-day-picker": "^9.13.0",
    "react-dropzone": "^14.3.0",
    "react-resizable-panels": "^2.1.0",
    "react-spinners": "^0.15.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.2.0",
    "tw-animate-css": "^1.2.5"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-i18next": "^15.0.0",
    "next-themes": "^0.4.0",
    "react-router-dom": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@lottiefiles/dotlottie-react": "^0.13.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react-i18next": { "optional": true },
    "next-themes": { "optional": true },
    "react-router-dom": { "optional": true },
    "@tanstack/react-query": { "optional": true },
    "@lottiefiles/dotlottie-react": { "optional": true }
  },
  "devDependencies": {
    "@lottiefiles/dotlottie-react": "^0.13.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.6.0"
  }
}
