{
  "name": "@transight-design/registry",
  "version": "0.0.0",
  "private": true,
  "description": "Transight Design System — 문서 사이트 + 레지스트리 정적 호스팅",
  "type": "module",
  "scripts": {
    "predev": "node ../../packages/ui/scripts/build-icons.mjs && node scripts/sync-registry.mjs && node scripts/extract-variants.mjs",
    "dev": "next dev --turbo --port 3002",
    "prebuild": "node ../../packages/ui/scripts/build-icons.mjs && node scripts/sync-registry.mjs && node scripts/extract-variants.mjs",
    "build": "next build",
    "start": "next start --port 3002",
    "pretypecheck": "node ../../packages/ui/scripts/build-icons.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .turbo public/r"
  },
  "dependencies": {
    "@transight-design/ui": "*",
    "i18next": "^23.16.0",
    "motion": "^12.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.6.0"
  }
}
