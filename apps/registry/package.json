{
  "name": "@transight-design/registry",
  "version": "0.0.0",
  "private": true,
  "description": "Transight Design System — 문서 사이트 + 레지스트리 정적 호스팅",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-registry.mjs && node scripts/extract-variants.mjs",
    "dev": "next dev --turbo --port 3000",
    "prebuild": "node scripts/sync-registry.mjs && node scripts/extract-variants.mjs",
    "build": "next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next .turbo public/r"
  },
  "dependencies": {
    "@transight-design/ui": "*",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.6.0"
  }
}
