{
  "name": "transight-design",
  "version": "0.0.0",
  "private": true,
  "description": "Transight Design System — shadcn-style distributable component registry",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "registry:build": "turbo run registry:build --filter=@transight-design/ui",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  }
}
