{
  "name": "transight-design",
  "version": "0.0.0",
  "private": true,
  "description": "Transight Design System — shadcn-style distributable component registry",
  "license": "MIT",
  "packageManager": "npm@11.6.4",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=@transight-design/registry",
    "lint": "npm run lint:design && npm run lint --workspaces --if-present",
    "lint:design": "node scripts/check-design-guidelines.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "registry:build": "npm run registry:build --workspace=@transight-design/ui",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "turbo": "^2.5.0",
    "typescript": "^5.6.0"
  }
}
